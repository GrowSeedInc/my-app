<%= form_with model: category,
      url: category.new_record? ? admin_category_majors_path : admin_category_major_path(category),
      class: "space-y-5" do |f| %>
  <%= render "shared/error_messages", object: category %>

  <div>
    <%= f.label :name, "大分類名", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
          class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          placeholder: "例: PC・周辺機器" %>
  </div>

  <div class="flex gap-3 pt-2 border-t border-gray-100">
    <%= f.submit category.new_record? ? "作成する" : "更新する",
          class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-md text-sm cursor-pointer transition-colors" %>
    <%= link_to "キャンセル", admin_category_majors_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-800 border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
