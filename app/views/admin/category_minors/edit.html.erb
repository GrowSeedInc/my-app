<% content_for :title, "小分類編集" %>

<div class="max-w-lg">
  <div class="flex justify-between items-center mb-4">
    <div>
      <h1 class="text-xl font-semibold text-gray-800">小分類編集</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= @category.name %></p>
    </div>
    <%= link_to "← 一覧に戻る", admin_category_minors_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <%= render "form",
          category: @category,
          major_categories: @major_categories,
          medium_categories: @medium_categories,
          selected_major_id: @category.parent&.parent_id %>
  </div>
</div>
