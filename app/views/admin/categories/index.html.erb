<% content_for :title, "カテゴリ管理" %>

<div>
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-xl font-semibold text-gray-800">カテゴリ管理</h1>
    <div class="flex gap-2">
      <% if policy(Category).export_csv? %>
        <%= link_to "CSV ダウンロード", export_csv_admin_categories_path,
              class: "bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium px-4 py-2 rounded-md transition-colors" %>
      <% end %>
      <%= link_to "＋ カテゴリを追加", new_admin_category_path,
            class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors" %>
    </div>
  </div>

  <%# インポートエラー表示 %>
  <% if flash[:import_errors].present? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
      <h3 class="text-sm font-semibold text-red-800 mb-2">インポートエラー（全件ロールバック済み）</h3>
      <table class="min-w-full text-xs">
        <thead>
          <tr class="text-left text-red-700">
            <th class="pr-4 pb-1 font-medium">行番号</th>
            <th class="pb-1 font-medium">エラー内容</th>
          </tr>
        </thead>
        <tbody>
          <% flash[:import_errors].each do |err| %>
            <tr class="border-t border-red-100">
              <td class="pr-4 py-1 text-red-600"><%= err["row"] %>行目</td>
              <td class="py-1 text-red-700"><%= err["message"] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%# CSV インポート %>
  <% if policy(Category).import_csv? %>
    <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
      <h3 class="text-sm font-semibold text-gray-700 mb-2">カテゴリ CSV インポート</h3>
      <%= form_with url: import_csv_admin_categories_path, method: :post, multipart: true do |f| %>
        <div class="flex items-center gap-3">
          <%= f.file_field :file, accept: ".csv", id: "category_csv_file", class: "hidden",
                onchange: "document.getElementById('category_csv_name').textContent = this.files[0]?.name || '選択されていません'" %>
          <label for="category_csv_file"
                 class="cursor-pointer bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium px-4 py-1.5 rounded-md transition-colors">
            CSV を選択
          </label>
          <span id="category_csv_name" class="text-sm text-gray-500 truncate max-w-xs">選択されていません</span>
          <%= f.submit "インポート", class: "bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium px-4 py-1.5 rounded-md cursor-pointer transition-colors" %>
        </div>
      <% end %>
      <p class="text-xs text-gray-400 mt-1.5">
        CSVファイル（5MB以下）
        <%= link_to "テンプレートをダウンロード", import_template_admin_categories_path, class: "text-blue-600 hover:text-blue-800" %>
      </p>
    </div>
  <% end %>

  <%# 検索フォーム %>
  <%= form_with url: admin_categories_path, method: :get, class: "bg-white border border-gray-200 rounded-lg p-4 mb-4" do |f| %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <%= f.label :keyword, "キーワード", class: "block text-xs font-medium text-gray-600 mb-1" %>
        <%= f.text_field :keyword, value: params[:keyword],
              placeholder: "カテゴリ名",
              class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      <div>
        <%= f.label :sort, "並び替え", class: "block text-xs font-medium text-gray-600 mb-1" %>
        <%= f.select :sort,
              [
                ["登録日（新しい順）",  "created_at"],
                ["登録日（古い順）",    "created_at_asc"],
                ["カテゴリ名（昇順）",  "name"],
                ["カテゴリ名（降順）",  "name_desc"],
                ["備品数（多い順）",    "equipments_count"],
                ["備品数（少ない順）",  "equipments_count_asc"]
              ],
              { selected: params[:sort] },
              class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>
    <div class="mt-3 flex gap-2">
      <%= f.submit "検索", class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-1.5 rounded-md cursor-pointer transition-colors" %>
      <%= link_to "リセット", admin_categories_path, class: "text-sm text-gray-500 hover:text-gray-700 px-4 py-1.5" %>
    </div>
  <% end %>

  <%# 一覧テーブル %>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">カテゴリ名</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">登録日時</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">備品数</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% @categories.each do |category| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= category.name %></td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= category.created_at.strftime("%Y/%m/%d %H:%M") %></td>
            <td class="px-4 py-3 text-sm text-gray-600 text-center"><%= category.equipments_count %></td>
            <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-medium space-x-3">
              <%= link_to "編集", edit_admin_category_path(category), class: "text-blue-600 hover:text-blue-800 transition-colors" %>
              <%= button_to "削除", admin_category_path(category), method: :delete,
                    data: { turbo_confirm: "「#{category.name}」を削除しますか？" },
                    class: "text-red-600 hover:text-red-800 bg-transparent border-0 cursor-pointer font-medium transition-colors" %>
            </td>
          </tr>
        <% end %>
        <% if @categories.to_a.empty? %>
          <tr>
            <td colspan="4" class="px-4 py-12 text-center text-sm text-gray-400">
              <% if params[:keyword].present? || params[:sort].present? %>
                該当するカテゴリが見つかりません
              <% else %>
                カテゴリが登録されていません
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# ページネーション %>
  <% if @pagination && @pagination.total_pages > 1 %>
    <div class="mt-4 flex items-center justify-between">
      <p class="text-sm text-gray-500">
        全 <%= @pagination.total_count %> 件中
        <%= (@pagination.page - 1) * @pagination.per_page + 1 %>–<%= [@pagination.page * @pagination.per_page, @pagination.total_count].min %> 件を表示
      </p>
      <div class="flex gap-2">
        <% if @pagination.prev_page %>
          <%= link_to "← 前へ", admin_categories_path(request.query_parameters.merge(page: @pagination.prev_page)),
                class: "px-3 py-1 text-sm border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
        <% end %>
        <% if @pagination.next_page %>
          <%= link_to "次へ →", admin_categories_path(request.query_parameters.merge(page: @pagination.next_page)),
                class: "px-3 py-1 text-sm border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
