<section>
  <h2 class="text-base font-semibold text-gray-700 mb-3">カテゴリ別在庫サマリー</h2>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">カテゴリ</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">備品数</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">総数</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">貸出中</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">利用可能数</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% summary.each do |row| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-4 py-3 text-sm font-medium text-gray-800">
              <%= row[:category]&.name || "（未分類）" %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-500 text-right">
              <%= row[:equipment_count] %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-500 text-right">
              <%= row[:total_count] %>
            </td>
            <td class="px-4 py-3 text-sm text-right">
              <% if row[:in_use_count] > 0 %>
                <span class="text-blue-700 font-medium"><%= row[:in_use_count] %></span>
              <% else %>
                <span class="text-gray-400">0</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-right">
              <% if row[:available_count] > 0 %>
                <span class="text-emerald-700 font-medium"><%= row[:available_count] %></span>
              <% else %>
                <span class="text-red-600 font-medium">0</span>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if summary.empty? %>
          <tr>
            <td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">
              登録された備品がありません
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
