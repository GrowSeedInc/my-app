<% content_for :title, "管理者ダッシュボード" %>

<div class="container mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">管理者ダッシュボード</h1>

  <%# カテゴリ別在庫サマリー %>
  <section class="mb-10">
    <h2 class="text-lg font-semibold text-gray-700 mb-4">カテゴリ別在庫サマリー</h2>
    <div class="bg-white shadow-sm rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">カテゴリ</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">備品数</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">総数</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">貸出中</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">利用可能数</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @summary.each do |row| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                <%= row[:category]&.name || "（未分類）" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right">
                <%= row[:equipment_count] %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-right">
                <%= row[:total_count] %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                <% if row[:in_use_count] > 0 %>
                  <span class="text-blue-700 font-medium"><%= row[:in_use_count] %></span>
                <% else %>
                  <span class="text-gray-400">0</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                <% if row[:available_count] > 0 %>
                  <span class="text-green-700 font-medium"><%= row[:available_count] %></span>
                <% else %>
                  <span class="text-red-600 font-medium">0</span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @summary.empty? %>
            <tr>
              <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-500">
                登録された備品がありません
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <%# 延滞中貸出一覧 %>
  <section>
    <h2 class="text-lg font-semibold text-gray-700 mb-4">
      延滞中の貸出
      <% if @overdue_loans.any? %>
        <span class="ml-2 bg-red-100 text-red-800 text-xs font-medium px-2 py-0.5 rounded-full">
          <%= @overdue_loans.count %>件
        </span>
      <% end %>
    </h2>
    <div class="bg-white shadow-sm rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ユーザー</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">備品名</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">管理番号</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">返却予定日</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">延滞日数</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @overdue_loans.each do |loan| %>
            <tr class="hover:bg-red-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= loan.user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= loan.equipment.name %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= loan.equipment.management_number %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= loan.expected_return_date.strftime("%Y/%m/%d") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-right">
                <span class="text-red-600 font-medium">
                  <%= (Date.today - loan.expected_return_date).to_i %>日
                </span>
              </td>
            </tr>
          <% end %>
          <% if @overdue_loans.empty? %>
            <tr>
              <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-500">
                延滞中の貸出はありません
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
