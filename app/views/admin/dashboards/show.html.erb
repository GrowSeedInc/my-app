<% content_for :title, "管理者ダッシュボード" %>

<div class="space-y-6">
  <h1 class="text-xl font-semibold text-gray-800">管理者ダッシュボード</h1>

  <%# KPIカード %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-white border border-gray-200 rounded-lg px-5 py-4 border-l-4 border-l-gray-400">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">備品総数</p>
      <p class="mt-1 text-2xl font-bold text-gray-800"><%= @summary.sum { |r| r[:equipment_count] } %></p>
      <p class="text-xs text-gray-400 mt-0.5">登録済み備品</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg px-5 py-4 border-l-4 border-l-blue-500">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">貸出中</p>
      <p class="mt-1 text-2xl font-bold text-blue-600"><%= @summary.sum { |r| r[:in_use_count] } %></p>
      <p class="text-xs text-gray-400 mt-0.5">現在貸出中</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg px-5 py-4 border-l-4 <%= @overdue_loans.any? ? 'border-l-red-500' : 'border-l-gray-200' %>">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">延滞中</p>
      <p class="mt-1 text-2xl font-bold <%= @overdue_loans.any? ? 'text-red-600' : 'text-gray-400' %>"><%= @overdue_loans.count %></p>
      <p class="text-xs text-gray-400 mt-0.5">返却期限超過</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg px-5 py-4 border-l-4 <%= @pending_loans_count > 0 ? 'border-l-amber-400' : 'border-l-gray-200' %>">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">承認待ち</p>
      <p class="mt-1 text-2xl font-bold <%= @pending_loans_count > 0 ? 'text-amber-500' : 'text-gray-400' %>"><%= @pending_loans_count %></p>
      <p class="text-xs text-gray-400 mt-0.5">申請中</p>
    </div>
  </div>

  <%# カテゴリ別在庫サマリー %>
  <section>
    <h2 class="text-base font-semibold text-gray-700 mb-3">カテゴリ別在庫サマリー</h2>
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">カテゴリ</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">備品数</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">総数</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">貸出中</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">利用可能数</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-100">
          <% @summary.each do |row| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 text-sm font-medium text-gray-800">
                <%= row[:category]&.name || "（未分類）" %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500 text-right">
                <%= row[:equipment_count] %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-500 text-right">
                <%= row[:total_count] %>
              </td>
              <td class="px-4 py-3 text-sm text-right">
                <% if row[:in_use_count] > 0 %>
                  <span class="text-blue-700 font-medium"><%= row[:in_use_count] %></span>
                <% else %>
                  <span class="text-gray-400">0</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-right">
                <% if row[:available_count] > 0 %>
                  <span class="text-emerald-700 font-medium"><%= row[:available_count] %></span>
                <% else %>
                  <span class="text-red-600 font-medium">0</span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @summary.empty? %>
            <tr>
              <td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">
                登録された備品がありません
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <%# データ移行ガイド %>
  <section>
    <h2 class="text-base font-semibold text-gray-700 mb-3">データ移行ガイド</h2>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-5">
      <p class="text-sm text-amber-800 mb-3 font-medium">Render 無料プランの DB リセット後は以下の順序でインポートしてください：</p>
      <ol class="space-y-2 text-sm text-amber-900">
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-5 h-5 bg-amber-400 text-white rounded-full flex items-center justify-center text-xs font-bold">1</span>
          <span>
            <strong>カテゴリ</strong> — <%= link_to "カテゴリ管理 → CSV インポート", admin_category_majors_path, class: "text-blue-700 hover:underline" %>
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-5 h-5 bg-amber-400 text-white rounded-full flex items-center justify-center text-xs font-bold">2</span>
          <span>
            <strong>ユーザー</strong> — <%= link_to "ユーザー管理 → CSV インポート", admin_users_path, class: "text-blue-700 hover:underline" %>
            （初期パスワード: <code class="bg-amber-100 px-1 rounded text-xs font-mono">password123</code>）
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-5 h-5 bg-amber-400 text-white rounded-full flex items-center justify-center text-xs font-bold">3</span>
          <span>
            <strong>備品</strong> — <%= link_to "備品一覧 → CSV インポート", equipments_path, class: "text-blue-700 hover:underline" %>
          </span>
        </li>
        <li class="flex items-start gap-2">
          <span class="flex-shrink-0 w-5 h-5 bg-amber-400 text-white rounded-full flex items-center justify-center text-xs font-bold">4</span>
          <span>
            <strong>貸出履歴</strong> — <%= link_to "貸出一覧 → CSV インポート", loans_path, class: "text-blue-700 hover:underline" %>
            （インポート後に在庫数が自動再計算されます）
          </span>
        </li>
      </ol>
      <p class="text-xs text-amber-700 mt-3">
        各インポートは All-or-nothing（エラー時は全件ロールバック）です。エラーが発生した場合は CSV を修正して再実行してください。
      </p>
    </div>
  </section>

  <%# 延滞中貸出一覧 %>
  <section>
    <h2 class="text-base font-semibold text-gray-700 mb-3 flex items-center gap-2">
      延滞中の貸出
      <% if @overdue_loans.any? %>
        <span class="bg-red-100 text-red-700 text-xs font-medium px-2 py-0.5 rounded-full">
          <%= @overdue_loans.count %>件
        </span>
      <% end %>
    </h2>
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ユーザー</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">備品名</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">管理番号</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">返却予定日</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">延滞日数</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-100">
          <% @overdue_loans.each do |loan| %>
            <tr class="hover:bg-red-50 transition-colors">
              <td class="px-4 py-3 text-sm text-gray-800"><%= loan.user.name.presence || loan.user.email %></td>
              <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= loan.equipment.name %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= loan.equipment.management_number %></td>
              <td class="px-4 py-3 text-sm text-gray-500">
                <%= loan.expected_return_date.strftime("%Y/%m/%d") %>
              </td>
              <td class="px-4 py-3 text-sm text-right">
                <span class="text-red-600 font-semibold">
                  <%= (Date.today - loan.expected_return_date).to_i %>日
                </span>
              </td>
            </tr>
          <% end %>
          <% if @overdue_loans.empty? %>
            <tr>
              <td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">
                延滞中の貸出はありません
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
