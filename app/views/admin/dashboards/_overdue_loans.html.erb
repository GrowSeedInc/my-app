<section>
  <h2 class="text-base font-semibold text-gray-700 mb-3 flex items-center gap-2">
    延滞中の貸出
    <% if overdue_loans.any? %>
      <span class="bg-red-100 text-red-700 text-xs font-medium px-2 py-0.5 rounded-full">
        <%= overdue_loans.count %>件
      </span>
    <% end %>
  </h2>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ユーザー</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">備品名</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">管理番号</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">返却予定日</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">延滞日数</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% overdue_loans.each do |loan| %>
          <tr class="hover:bg-red-50 transition-colors">
            <td class="px-4 py-3 text-sm text-gray-800"><%= loan.user.name.presence || loan.user.email %></td>
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= loan.equipment.name %></td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= loan.equipment.management_number %></td>
            <td class="px-4 py-3 text-sm text-gray-500">
              <%= format_date(loan.expected_return_date) %>
            </td>
            <td class="px-4 py-3 text-sm text-right">
              <span class="text-red-600 font-semibold">
                <%= (Date.today - loan.expected_return_date).to_i %>日
              </span>
            </td>
          </tr>
        <% end %>
        <% if overdue_loans.empty? %>
          <tr>
            <td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">
              延滞中の貸出はありません
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
