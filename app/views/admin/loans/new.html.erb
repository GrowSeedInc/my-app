<% content_for :title, "管理者代理貸出登録" %>

<div class="max-w-lg">
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-xl font-semibold text-gray-800">管理者代理貸出登録</h1>
    <%= link_to "← 貸出一覧に戻る", loans_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <%= form_with model: [:admin, @loan], url: admin_loans_path, class: "space-y-5" do |f| %>
      <%= render "shared/error_messages", object: @loan %>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">登録モード</label>
        <div class="flex gap-6">
          <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
            <%= radio_button_tag "loan[mode]", "apply", true, class: "text-blue-600" %>
            代理申請（承認フローあり）
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
            <%= radio_button_tag "loan[mode]", "direct", false, class: "text-blue-600" %>
            直接記録（即時貸出）
          </label>
        </div>
      </div>

      <div>
        <%= label_tag "loan[user_id]", "対象ユーザー", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= select_tag "loan[user_id]",
              options_for_select(
                @users.map { |u| ["#{u.name}（#{u.email}）", u.id] },
                @loan.user_id
              ),
              include_blank: "ユーザーを選択してください",
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :equipment_id, "備品", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :equipment_id,
              options_for_select(
                @equipments.map { |e| [e.name, e.id] },
                @loan.equipment_id
              ),
              { include_blank: "備品を選択してください" },
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :start_date, "貸出開始日", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :start_date,
              value: @loan.start_date,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :expected_return_date, "返却予定日", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :expected_return_date,
              value: @loan.expected_return_date,
              class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="flex gap-3 pt-2 border-t border-gray-100">
        <%= f.submit "登録する",
              class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-md text-sm cursor-pointer transition-colors" %>
        <%= link_to "キャンセル", loans_path,
              class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-800 border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
