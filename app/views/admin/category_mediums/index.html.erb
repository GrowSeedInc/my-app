<% content_for :title, "中分類管理" %>

<div>
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-xl font-semibold text-gray-800">中分類管理</h1>
    <%= link_to "＋ 中分類を追加", new_admin_category_medium_path,
          class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors" %>
  </div>

  <%# 一覧テーブル %>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">中分類名</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">親大分類</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">小分類数</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">登録日時</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% @mediums.each do |medium| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= medium.name %></td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= medium.parent&.name %></td>
            <td class="px-4 py-3 text-sm text-gray-600 text-center"><%= medium.children.size %></td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= medium.created_at.strftime("%Y/%m/%d %H:%M") %></td>
            <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-medium space-x-3">
              <%= link_to "編集", edit_admin_category_medium_path(medium), class: "text-blue-600 hover:text-blue-800 transition-colors" %>
              <%= button_to "削除", admin_category_medium_path(medium), method: :delete,
                    data: { turbo_confirm: "「#{medium.name}」を削除しますか？" },
                    class: "text-red-600 hover:text-red-800 bg-transparent border-0 cursor-pointer font-medium transition-colors" %>
            </td>
          </tr>
        <% end %>
        <% if @mediums.empty? %>
          <tr>
            <td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">
              中分類が登録されていません
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# ナビゲーション %>
  <div class="mt-4 flex gap-3 text-sm">
    <%= link_to "← 大分類管理", admin_category_majors_path, class: "text-blue-600 hover:text-blue-800" %>
    <%= link_to "小分類管理 →", admin_category_minors_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>
</div>
