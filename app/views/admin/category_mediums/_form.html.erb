<%= form_with model: category,
      url: category.new_record? ? admin_category_mediums_path : admin_category_medium_path(category),
      class: "space-y-5" do |f| %>
  <% if category.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="text-sm font-medium text-red-800 mb-2">入力内容を確認してください</h3>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% category.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :parent_id, "親大分類", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <select name="category[parent_id]" id="category_parent_id"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
      <%= options_for_select(
            [["大分類を選択してください", ""]].concat(major_categories.map { |c| [c.name, c.id] }),
            category.parent_id
          ) %>
    </select>
  </div>

  <div>
    <%= f.label :name, "中分類名", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
          class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          placeholder: "例: ノートPC" %>
  </div>

  <div class="flex gap-3 pt-2 border-t border-gray-100">
    <%= f.submit category.new_record? ? "作成する" : "更新する",
          class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-md text-sm cursor-pointer transition-colors" %>
    <%= link_to "キャンセル", admin_category_majors_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-800 border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
  </div>
<% end %>
