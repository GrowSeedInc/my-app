<% content_for :title, "ユーザー管理" %>

<div>
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-xl font-semibold text-gray-800">ユーザー管理</h1>
    <div class="flex gap-2">
      <% if policy(User).export_csv? %>
        <%= link_to "CSV ダウンロード", export_csv_admin_users_path,
              class: "bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium px-4 py-2 rounded-md transition-colors" %>
      <% end %>
      <%= link_to "＋ ユーザーを追加", new_admin_user_path,
            class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors" %>
    </div>
  </div>

  <%# インポートエラー表示 %>
  <% if flash[:import_errors].present? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
      <h3 class="text-sm font-semibold text-red-800 mb-2">インポートエラー（全件ロールバック済み）</h3>
      <table class="min-w-full text-xs">
        <thead>
          <tr class="text-left text-red-700">
            <th class="pr-4 pb-1 font-medium">行番号</th>
            <th class="pb-1 font-medium">エラー内容</th>
          </tr>
        </thead>
        <tbody>
          <% flash[:import_errors].each do |err| %>
            <tr class="border-t border-red-100">
              <td class="pr-4 py-1 text-red-600"><%= err["row"] %>行目</td>
              <td class="py-1 text-red-700"><%= err["message"] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if flash[:import_errors_truncated]&.positive? %>
        <p class="mt-2 text-xs text-red-600">他 <%= flash[:import_errors_truncated] %> 件のエラーがあります。CSVを修正して再インポートしてください。</p>
      <% end %>
    </div>
  <% end %>

  <%# CSV インポート %>
  <% if policy(User).import_csv? %>
    <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
      <h3 class="text-sm font-semibold text-gray-700 mb-2">ユーザー CSV インポート</h3>
      <%= form_with url: import_csv_admin_users_path, method: :post, multipart: true do |f| %>
        <div class="flex items-center gap-3">
          <%= f.file_field :file, accept: ".csv", id: "user_csv_file", class: "hidden",
                onchange: "document.getElementById('user_csv_name').textContent = this.files[0]?.name || '選択されていません'" %>
          <label for="user_csv_file"
                 class="cursor-pointer bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium px-4 py-1.5 rounded-md transition-colors">
            CSV を選択
          </label>
          <span id="user_csv_name" class="text-sm text-gray-500 truncate max-w-xs">選択されていません</span>
          <%= f.submit "インポート", class: "bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium px-4 py-1.5 rounded-md cursor-pointer transition-colors" %>
        </div>
      <% end %>
      <p class="text-xs text-gray-400 mt-1.5">
        CSVファイル（5MB以下）・初期パスワード: <span class="font-mono">password123</span>（インポート後に変更を促してください）
        <%= link_to "テンプレートをダウンロード", import_template_admin_users_path, class: "text-blue-600 hover:text-blue-800" %>
      </p>
    </div>
  <% end %>

  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">氏名</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">メールアドレス</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ロール</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">登録日</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% @users.each do |user| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= user.name.presence || "—" %></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= user.email %></td>
            <td class="px-4 py-3">
              <% if user.admin? %>
                <span class="bg-blue-100 text-blue-800 px-2 py-0.5 rounded-full text-xs font-medium">管理者</span>
              <% else %>
                <span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full text-xs font-medium">一般</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= user.created_at.strftime("%Y/%m/%d") %></td>
            <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-medium space-x-3">
              <%= link_to "編集", edit_admin_user_path(user), class: "text-blue-600 hover:text-blue-800 transition-colors" %>
              <% if user != current_user %>
                <%= button_to "削除", admin_user_path(user), method: :delete,
                      data: { turbo_confirm: "#{user.email} を削除しますか？" },
                      class: "text-red-600 hover:text-red-800 bg-transparent border-0 cursor-pointer font-medium transition-colors" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @users.empty? %>
          <tr>
            <td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">ユーザーが見つかりません</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
