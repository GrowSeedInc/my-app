<% content_for :title, "ユーザー管理" %>

<div>
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">ユーザー管理</h1>
    <%= link_to "ユーザーを追加", new_admin_user_path,
          class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-4 py-2 rounded-lg" %>
  </div>

  <div class="bg-white shadow-sm rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">氏名</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">メールアドレス</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ロール</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">登録日</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @users.each do |user| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= user.name.presence || "—" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.email %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if user.admin? %>
                <span class="bg-purple-100 text-purple-800 px-2 py-1 rounded-full text-xs font-medium">管理者</span>
              <% else %>
                <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded-full text-xs font-medium">一般</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.created_at.strftime("%Y/%m/%d") %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
              <%= link_to "編集", edit_admin_user_path(user), class: "text-indigo-600 hover:text-indigo-900" %>
              <% if user != current_user %>
                <%= button_to "削除", admin_user_path(user), method: :delete,
                      data: { turbo_confirm: "#{user.email} を削除しますか？" },
                      class: "text-red-600 hover:text-red-900 bg-transparent border-0 cursor-pointer font-medium" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @users.empty? %>
          <tr>
            <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-500">ユーザーが見つかりません</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
