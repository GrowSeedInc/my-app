<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "備品管理システム" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="備品管理システム">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 min-h-screen text-gray-900 antialiased">

    <% if user_signed_in? %>

      <div class="flex min-h-screen"
           data-controller="sidebar"
           data-action="click@window->sidebar#handleWindowClick">

        <%# サイドバーパネル %>
        <aside data-sidebar-target="panel"
               class="fixed inset-y-0 left-0 z-30 w-64 bg-white border-r border-gray-200 flex flex-col transition-transform duration-300 -translate-x-full">

          <%# ロゴ %>
          <div class="flex items-center h-14 px-4 border-b border-gray-200 shrink-0 border-t-4 border-blue-600">
            <%= link_to root_path, class: "flex items-center gap-2 font-bold text-blue-600 hover:text-blue-700 transition-colors text-sm tracking-wide" do %>
              <span class="text-base">▤</span>
              <span>備品管理システム</span>
            <% end %>
          </div>

          <%# ナビゲーション %>
          <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto text-sm">
            <%= link_to "備品一覧", equipments_path,
                  class: "flex items-center gap-2 px-3 py-2 rounded transition-colors font-medium w-full #{controller_name == 'equipments' ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}" %>
            <%= link_to "貸出一覧", loans_path,
                  class: "flex items-center gap-2 px-3 py-2 rounded transition-colors font-medium w-full #{controller_name == 'loans' ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}" %>
            <%= link_to "マイページ", mypage_path,
                  class: "flex items-center gap-2 px-3 py-2 rounded transition-colors font-medium w-full #{controller_name == 'mypages' ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}" %>
            <% if current_user.admin? %>
              <hr class="my-2 border-gray-200">
              <%= link_to "ダッシュボード", admin_dashboard_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded transition-colors font-medium w-full #{controller_name == 'dashboards' ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}" %>
              <%= link_to "ユーザー管理", admin_users_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded transition-colors font-medium w-full #{controller_name == 'users' && controller.class.module_parent == Admin ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}" %>
              <%= link_to "カテゴリ管理", admin_category_majors_path,
                    class: "flex items-center gap-2 px-3 py-2 rounded transition-colors font-medium w-full #{controller_name.start_with?('category_') && controller.class.module_parent == Admin ? 'bg-blue-50 text-blue-700' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}" %>
            <% end %>
          </nav>

          <%# ユーザー情報・ログアウト %>
          <div class="shrink-0 px-4 py-3 border-t border-gray-200">
            <div class="mb-2">
              <p class="text-xs font-semibold text-gray-800 leading-tight truncate"><%= current_user.name.presence || current_user.email %></p>
              <% if current_user.admin? %>
                <p class="text-xs text-blue-600 font-medium mt-0.5">管理者</p>
              <% else %>
                <p class="text-xs text-gray-400 mt-0.5">一般ユーザー</p>
              <% end %>
            </div>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
                  class: "w-full text-xs text-gray-500 hover:text-gray-700 border border-gray-300 hover:border-gray-400 px-3 py-1.5 rounded cursor-pointer bg-white transition-colors" %>
          </div>

        </aside>

        <%# モバイルスクリム %>
        <div data-sidebar-target="scrim"
             data-action="click->sidebar#close"
             class="fixed inset-0 z-20 bg-black/50 lg:hidden hidden">
        </div>

        <%# メインコンテンツエリア %>
        <div data-sidebar-target="main"
             class="flex-1 min-w-0 transition-all duration-300 lg:ml-0">

          <%# ハンバーガーボタンバー %>
          <div class="bg-white border-b border-gray-200 border-t-4 border-blue-600 px-4 h-14 flex items-center sticky top-0 z-10">
            <button data-sidebar-target="hamburger"
                    data-action="click->sidebar#toggle"
                    aria-expanded="false"
                    aria-label="メニューを開閉する"
                    class="p-2 rounded text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>

          <%# フラッシュメッセージ %>
          <% if notice.present? %>
            <div class="px-4 sm:px-6 lg:px-8 pt-4">
              <div class="flex items-center gap-2 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm">
                <span class="text-green-500 font-bold">✓</span>
                <%= notice %>
              </div>
            </div>
          <% end %>
          <% if alert.present? %>
            <div class="px-4 sm:px-6 lg:px-8 pt-4">
              <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm">
                <span class="text-red-500 font-bold">✕</span>
                <%= alert %>
              </div>
            </div>
          <% end %>

          <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
            <%= yield %>
          </main>

        </div>

      </div>

    <% else %>

      <%# 未ログイン時: サイドバーなし %>
      <% if notice.present? %>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
          <div class="flex items-center gap-2 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm">
            <span class="text-green-500 font-bold">✓</span>
            <%= notice %>
          </div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
          <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm">
            <span class="text-red-500 font-bold">✕</span>
            <%= alert %>
          </div>
        </div>
      <% end %>

      <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <%= yield %>
      </main>

    <% end %>

  </body>
</html>
