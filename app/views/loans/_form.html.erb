<%= form_with model: loan, url: loans_path, class: "space-y-5" do |f| %>
  <%= render "shared/error_messages", object: loan %>

  <div>
    <%= f.label :equipment_id, "備品", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :equipment_id,
          options_for_select(
            equipments.map { |e|
              label = e.repair? ? "#{e.name}（修理中・貸出不可）" : e.name
              e.repair? ? [ label, e.id, { disabled: true } ] : [ label, e.id ]
            },
            loan.equipment_id
          ),
          { include_blank: "備品を選択してください" },
          class: "w-full border #{ loan.errors[:equipment_id].any? ? 'border-red-400' : 'border-gray-300' } rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    <% if loan.errors[:equipment_id].any? %>
      <p class="mt-1 text-xs text-red-600"><%= loan.errors[:equipment_id].first %></p>
    <% end %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :start_date, "貸出開始日", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :start_date,
            value: loan.start_date || Date.today,
            class: "w-full border #{ loan.errors[:start_date].any? ? 'border-red-400' : 'border-gray-300' } rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <% if loan.errors[:start_date].any? %>
        <p class="mt-1 text-xs text-red-600"><%= loan.errors[:start_date].first %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :expected_return_date, "返却予定日", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :expected_return_date,
            value: loan.expected_return_date,
            class: "w-full border #{ loan.errors[:expected_return_date].any? ? 'border-red-400' : 'border-gray-300' } rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <% if loan.errors[:expected_return_date].any? %>
        <p class="mt-1 text-xs text-red-600"><%= loan.errors[:expected_return_date].first %></p>
      <% end %>
    </div>
  </div>

  <div class="flex justify-end gap-3 pt-2 border-t border-gray-100">
    <%= link_to "キャンセル", loans_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-800 border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
    <%= f.submit "申請する",
          class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-md text-sm cursor-pointer transition-colors" %>
  </div>
<% end %>
