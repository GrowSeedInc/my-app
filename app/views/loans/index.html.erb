<% content_for :title, "貸出一覧" %>

<div>
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-xl font-semibold text-gray-800">貸出一覧</h1>
    <div class="flex gap-2">
      <% if policy(Loan).export_csv? %>
        <%= link_to "CSV ダウンロード", export_csv_loans_path(request.query_parameters),
              class: "bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium px-4 py-2 rounded-md transition-colors",
              title: current_user.admin? ? "全貸出履歴" : "自分の貸出のみ" %>
      <% end %>
      <%= link_to "＋ 貸出申請", new_loan_path,
            class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors" %>
      <% if current_user.admin? %>
        <%= link_to "＋ 管理者代理貸出登録", new_admin_loan_path,
              class: "bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors" %>
      <% end %>
    </div>
  </div>

  <%# インポートエラー表示 %>
  <% if flash[:import_errors].present? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
      <h3 class="text-sm font-semibold text-red-800 mb-2">インポートエラー（全件ロールバック済み）</h3>
      <table class="min-w-full text-xs">
        <thead>
          <tr class="text-left text-red-700">
            <th class="pr-4 pb-1 font-medium">行番号</th>
            <th class="pb-1 font-medium">エラー内容</th>
          </tr>
        </thead>
        <tbody>
          <% flash[:import_errors].each do |err| %>
            <tr class="border-t border-red-100">
              <td class="pr-4 py-1 text-red-600"><%= err["row"] %>行目</td>
              <td class="py-1 text-red-700"><%= err["message"] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if flash[:import_errors_truncated]&.positive? %>
        <p class="mt-2 text-xs text-red-600">他 <%= flash[:import_errors_truncated] %> 件のエラーがあります。CSVを修正して再インポートしてください。</p>
      <% end %>
    </div>
  <% end %>

  <%# 管理者向け貸出履歴 CSV インポート %>
  <% if current_user.admin? && policy(Loan).import_csv? %>
    <div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
      <h3 class="text-sm font-semibold text-gray-700 mb-2">貸出履歴 CSV インポート</h3>
      <%= form_with url: import_csv_admin_loans_path, method: :post, multipart: true do |f| %>
        <div class="flex items-center gap-3">
          <%= f.file_field :file, accept: ".csv", id: "loan_csv_file", class: "hidden",
                onchange: "document.getElementById('loan_csv_name').textContent = this.files[0]?.name || '選択されていません'" %>
          <label for="loan_csv_file"
                 class="cursor-pointer bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium px-4 py-1.5 rounded-md transition-colors">
            CSV を選択
          </label>
          <span id="loan_csv_name" class="text-sm text-gray-500 truncate max-w-xs">選択されていません</span>
          <%= f.submit "インポート", class: "bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium px-4 py-1.5 rounded-md cursor-pointer transition-colors" %>
        </div>
      <% end %>
      <p class="text-xs text-gray-400 mt-1.5">
        CSVファイル（5MB以下）・インポート後に在庫数が自動再計算されます
        <%= link_to "テンプレートをダウンロード", import_template_admin_loans_path, class: "text-blue-600 hover:text-blue-800" %>
      </p>
    </div>
  <% end %>

  <%# 一般ユーザー向け注意書き %>
  <% unless current_user.admin? %>
    <p class="text-xs text-gray-400 mb-3">※ CSV ダウンロードはあなた自身の貸出データのみが対象です</p>
  <% end %>

  <%# 管理者向けフィルタフォーム %>
  <% if current_user.admin? %>
    <%= form_with url: loans_path, method: :get, class: "bg-white border border-gray-200 rounded-lg p-4 mb-4" do |f| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <div>
          <%= f.label :user_id, "ユーザー", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= f.select :user_id,
                options_from_collection_for_select(@users_for_filter, :id, :email, params[:user_id]),
                { include_blank: "すべて" },
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>
        <div>
          <%= f.label :equipment_id, "備品", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= f.select :equipment_id,
                options_from_collection_for_select(@equipments_for_filter, :id, :name, params[:equipment_id]),
                { include_blank: "すべて" },
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>
        <div>
          <%= f.label :status, "ステータス", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= f.select :status,
                [["承認待ち", "pending_approval"], ["貸出中", "active"], ["返却済", "returned"], ["延滞中", "overdue"]],
                { include_blank: "すべて", selected: params[:status] },
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>
        <div>
          <%= f.label :date_from, "貸出開始日（以降）", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= f.date_field :date_from, value: params[:date_from],
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>
        <div>
          <%= f.label :date_to, "返却予定日（以前）", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= f.date_field :date_to, value: params[:date_to],
                class: "w-full border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>
      </div>
      <div class="mt-3 flex gap-2">
        <%= f.submit "絞り込む", class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-1.5 rounded-md cursor-pointer transition-colors" %>
        <%= link_to "リセット", loans_path, class: "text-sm text-gray-500 hover:text-gray-700 px-4 py-1.5" %>
      </div>
    <% end %>
  <% end %>

  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-slate-50">
        <tr>
          <% if current_user.admin? %>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">申請者</th>
          <% end %>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">備品名</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">管理番号</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">貸出開始日</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">返却予定日</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">実返却日</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ステータス</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% @loans.each do |loan| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <% if current_user.admin? %>
              <td class="px-4 py-3 text-sm text-gray-700 whitespace-nowrap"><%= loan.user.name.presence || loan.user.email %></td>
            <% end %>
            <td class="px-4 py-3 text-sm font-medium text-gray-900 whitespace-nowrap"><%= loan.equipment.name %></td>
            <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap"><%= loan.equipment.management_number %></td>
            <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap"><%= loan.start_date.strftime("%Y/%m/%d") %></td>
            <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap"><%= loan.expected_return_date.strftime("%Y/%m/%d") %></td>
            <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap">
              <%= loan.actual_return_date&.strftime("%Y/%m/%d") || "—" %>
            </td>
            <td class="px-4 py-3 whitespace-nowrap">
              <span class="<%= loan_status_badge_class(loan.status) %> px-2 py-0.5 rounded-full text-xs font-medium">
                <%= t("loan.status.#{loan.status}") %>
              </span>
            </td>
            <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-medium space-x-2">
              <% if policy(loan).approve? && loan.pending_approval? %>
                <%= button_to "承認", approve_loan_path(loan), method: :patch,
                      data: { turbo_confirm: "#{loan.equipment.name} の貸出申請を承認しますか？" },
                      class: "bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-medium px-3 py-1 rounded-md transition-colors" %>
              <% end %>
              <% if policy(loan).return_loan? && (loan.active? || loan.overdue?) %>
                <%= button_to "返却", return_loan_path(loan), method: :patch,
                      data: { turbo_confirm: "#{loan.equipment.name} を返却しますか？" },
                      class: "bg-blue-600 hover:bg-blue-700 text-white text-xs font-medium px-3 py-1 rounded-md transition-colors" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @loans.to_a.empty? %>
          <tr>
            <td colspan="<%= current_user.admin? ? 8 : 7 %>" class="px-4 py-12 text-center text-sm text-gray-400">
              貸出記録がありません
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# ページネーション %>
  <% if @pagination && @pagination.total_pages > 1 %>
    <div class="mt-4 flex items-center justify-between">
      <p class="text-sm text-gray-500">
        全 <%= @pagination.total_count %> 件中
        <%= (@pagination.page - 1) * @pagination.per_page + 1 %>–<%= [@pagination.page * @pagination.per_page, @pagination.total_count].min %> 件を表示
      </p>
      <div class="flex gap-2">
        <% if @pagination.prev_page %>
          <%= link_to "← 前へ", loans_path(request.query_parameters.merge(page: @pagination.prev_page)),
                class: "px-3 py-1 text-sm border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
        <% end %>
        <% if @pagination.next_page %>
          <%= link_to "次へ →", loans_path(request.query_parameters.merge(page: @pagination.next_page)),
                class: "px-3 py-1 text-sm border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
