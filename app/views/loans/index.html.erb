<% content_for :title, "貸出一覧" %>

<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">貸出一覧</h1>
    <%= link_to "貸出申請", new_loan_path,
          class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-4 py-2 rounded-lg" %>
  </div>

  <% if notice %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
      <%= notice %>
    </div>
  <% end %>

  <% if alert %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <%= alert %>
    </div>
  <% end %>

  <div class="bg-white shadow-sm rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <% if current_user.admin? %>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">申請者</th>
          <% end %>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">備品名</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">管理番号</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">貸出開始日</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">返却予定日</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ステータス</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @loans.each do |loan| %>
          <tr class="hover:bg-gray-50">
            <% if current_user.admin? %>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= loan.user.email %></td>
            <% end %>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= loan.equipment.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= loan.equipment.management_number %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= loan.start_date.strftime("%Y/%m/%d") %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= loan.expected_return_date.strftime("%Y/%m/%d") %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="<%= loan_status_badge_class(loan.status) %> px-2 py-1 rounded-full text-xs font-medium">
                <%= t("loan.status.#{loan.status}") %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
              <% if policy(loan).approve? && loan.pending_approval? %>
                <%= button_to "承認", approve_loan_path(loan), method: :patch,
                      class: "bg-green-600 hover:bg-green-700 text-white text-xs font-medium px-3 py-1 rounded-lg" %>
              <% end %>
              <% if policy(loan).return_loan? && (loan.active? || loan.overdue?) %>
                <%= button_to "返却", return_loan_path(loan), method: :patch,
                      data: { turbo_confirm: "#{loan.equipment.name} を返却しますか？" },
                      class: "bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-medium px-3 py-1 rounded-lg" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @loans.empty? %>
          <tr>
            <td colspan="<%= current_user.admin? ? 7 : 6 %>" class="px-6 py-10 text-center text-sm text-gray-500">
              貸出記録がありません
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
