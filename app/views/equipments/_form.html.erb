<%= form_with model: equipment, class: "space-y-5" do |f| %>
  <% if equipment.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="text-sm font-medium text-red-800 mb-2">入力内容を確認してください</h3>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% equipment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "備品名", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
          class: "w-full border #{ equipment.errors[:name].any? ? 'border-red-400' : 'border-gray-300' } rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          placeholder: "例: ノートPC" %>
    <% if equipment.errors[:name].any? %>
      <p class="mt-1 text-xs text-red-600"><%= equipment.errors[:name].first %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :management_number, "管理番号", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :management_number,
          class: "w-full border #{ equipment.errors[:management_number].any? ? 'border-red-400' : 'border-gray-300' } rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          placeholder: "例: EQ-001" %>
    <% if equipment.errors[:management_number].any? %>
      <p class="mt-1 text-xs text-red-600"><%= equipment.errors[:management_number].first %></p>
    <% end %>
  </div>

  <div data-controller="category-select"
       data-category-select-mediums-url-value="<%= by_major_admin_category_mediums_path %>"
       data-category-select-minors-url-value="<%= by_medium_admin_category_minors_path %>"
       data-category-select-mode-value="form"
       data-category-select-selected-major-value="<%= @category_major&.id %>"
       data-category-select-selected-medium-value="<%= @category_medium&.id %>"
       data-category-select-selected-minor-value="<%= @category_minor&.id %>"
       class="space-y-3">

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">大分類</label>
      <%= select_tag :category_major,
            options_from_collection_for_select(Category.major.order(:name), :id, :name, @category_major&.id),
            include_blank: "大分類を選択",
            class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
            data: { category_select_target: "major", action: "change->category-select#majorChange" } %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">中分類</label>
      <select name="category_medium"
              data-category-select-target="medium"
              data-action="change->category-select#mediumChange"
              class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        <option value="">中分類を選択</option>
      </select>
    </div>

    <div>
      <%= f.label :category_id, "小分類", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :category_id,
            [],
            { include_blank: "小分類を選択" },
            class: "w-full border #{ equipment.errors[:category_id].any? ? 'border-red-400' : 'border-gray-300' } rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
            data: { category_select_target: "minor" } %>
      <% if equipment.errors[:category_id].any? %>
        <p class="mt-1 text-xs text-red-600"><%= equipment.errors[:category_id].first %></p>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :total_count, "総数", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :total_count, min: 0,
            class: "w-full border #{ equipment.errors[:total_count].any? ? 'border-red-400' : 'border-gray-300' } rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <% if equipment.errors[:total_count].any? %>
        <p class="mt-1 text-xs text-red-600"><%= equipment.errors[:total_count].first %></p>
      <% end %>
    </div>

    <div>
      <%= f.label :available_count, "貸出可能数", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :available_count, min: 0,
            class: "w-full border #{ equipment.errors[:available_count].any? ? 'border-red-400' : 'border-gray-300' } rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      <% if equipment.errors[:available_count].any? %>
        <p class="mt-1 text-xs text-red-600"><%= equipment.errors[:available_count].first %></p>
      <% end %>
    </div>
  </div>

  <div>
    <%= f.label :status, "ステータス", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :status,
          Equipment.statuses.keys.map { |s| [t("equipment.status.#{s}"), s] },
          {},
          class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <%= f.label :low_stock_threshold, "在庫不足閾値", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <p class="text-xs text-gray-400 mb-1">貸出可能数がこの値を下回るとアラートを送信します</p>
    <%= f.number_field :low_stock_threshold, min: 0,
          class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <%= f.label :description, "説明", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3,
          class: "w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          placeholder: "備品の説明や注意事項など" %>
  </div>

  <div class="flex justify-end gap-3 pt-2 border-t border-gray-100">
    <%= link_to "キャンセル", equipments_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-800 border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" %>
    <%= f.submit equipment.persisted? ? "更新する" : "登録する",
          class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-md text-sm cursor-pointer transition-colors" %>
  </div>
<% end %>
