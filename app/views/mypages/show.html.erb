<% content_for :title, "マイページ" %>

<div class="space-y-6">
  <h1 class="text-xl font-semibold text-gray-800">マイページ</h1>

  <%# 現在の貸出 %>
  <section>
    <h2 class="text-base font-semibold text-gray-700 mb-3">現在の貸出</h2>
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">備品名</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">管理番号</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">貸出開始日</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">返却予定日</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ステータス</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-100">
          <% @active_loans.each do |loan| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= loan.equipment.name %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= loan.equipment.management_number %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= format_date(loan.start_date) %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= format_date(loan.expected_return_date) %></td>
              <td class="px-4 py-3">
                <%= render "shared/loan_status_badge", status: loan.status %>
              </td>
            </tr>
          <% end %>
          <% if @active_loans.empty? %>
            <tr>
              <td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">現在貸出中の備品はありません</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <%# 過去の貸出履歴 %>
  <section>
    <h2 class="text-base font-semibold text-gray-700 mb-3">過去の貸出履歴</h2>
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">備品名</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">管理番号</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">貸出開始日</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">返却予定日</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">実返却日</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-100">
          <% @past_loans.each do |loan| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= loan.equipment.name %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= loan.equipment.management_number %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= format_date(loan.start_date) %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= format_date(loan.expected_return_date) %></td>
              <td class="px-4 py-3 text-sm text-gray-500">
                <%= format_date(loan.actual_return_date) %>
              </td>
            </tr>
          <% end %>
          <% if @past_loans.empty? %>
            <tr>
              <td colspan="5" class="px-4 py-12 text-center text-sm text-gray-400">過去の貸出履歴はありません</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
